TZ=Asia/Seoul

# ── 볼트 연결 (설정 시 자동 연결) ───────────────────────────────────────────
OBSIDIAN_VAULT_NAME=   # ob sync-list-remote 로 확인
OBSIDIAN_DEVICE_NAME=  # 이 서버를 식별할 이름 (예: home-server)
OBSIDIAN_E2E_PASSWORD= # E2E 암호화 사용 시에만 입력

# ── Obsidian Sync 설정 ───────────────────────────────────────────────────────
# 싱크할 설정 카테고리 (쉼표 구분, 비워두면 기본값 사용)
# 선택지: app, appearance, appearance-data, hotkey,
#         core-plugin, core-plugin-data, community-plugin, community-plugin-data
# 예) 커뮤니티 플러그인 포함 전체:
# SYNC_CONFIGS=app,appearance,appearance-data,hotkey,core-plugin,core-plugin-data,community-plugin,community-plugin-data
SYNC_CONFIGS=

# 싱크할 첨부파일 타입 (쉼표 구분, 비워두면 기본값 사용)
# 선택지: image, audio, video, pdf, unsupported
# 예) 모든 타입:
# SYNC_FILE_TYPES=image,audio,video,pdf,unsupported
SYNC_FILE_TYPES=

# 충돌 해결 전략: merge(기본) 또는 conflict
SYNC_CONFLICT_STRATEGY=

# 싱크 모드: bidirectional(기본), pull-only, mirror-remote
SYNC_MODE=

# 싱크 제외 폴더 (쉼표 구분, 비워두면 제외 없음)
SYNC_EXCLUDED_FOLDERS=
